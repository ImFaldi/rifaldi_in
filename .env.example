# Salin file ini menjadi .env.local, lalu isi nilainya.
# Untuk deployment, isi variabel yang sama di dashboard platform (Vercel/Netlify/dll).

# ─── Site / Public Meta ────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase (server + client) ────────────────────────────────────────────────
# Wajib isi NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY.
# SUPABASE_URL opsional sebagai fallback di server.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Secret untuk session auth dashboard (wajib, random panjang)
AUTH_SECRET=

# ─── Social Media (public) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SOCIAL_GITHUB=
NEXT_PUBLIC_SOCIAL_LINKEDIN=
NEXT_PUBLIC_SOCIAL_EMAIL=

# ─── GitHub Repos API (opsional) ───────────────────────────────────────────────
# Nama repo dipisah koma, contoh: my-app,another-repo,cool-project
GITHUB_FEATURED_REPOS=
# Opsional, untuk rate limit GitHub lebih tinggi
GITHUB_TOKEN=

# ─── Contact Form Email (server) ───────────────────────────────────────────────
# Wajib untuk kirim form Contact via API /api/contact
RESEND_API_KEY=
CONTACT_TO_EMAIL=
# Gunakan sender terverifikasi domain sendiri saat production
CONTACT_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>

# ─── Contact Page (public display) ─────────────────────────────────────────────
NEXT_PUBLIC_CONTACT_ADDRESS=Jakarta, Indonesia
NEXT_PUBLIC_CONTACT_MAP_EMBED_URL=https://www.google.com/maps?q=Jakarta+Indonesia&output=embed
NEXT_PUBLIC_CONTACT_MAP_LINK=https://maps.google.com/?q=Jakarta+Indonesia

# ─── Contact Fallback WhatsApp (opsional) ──────────────────────────────────────
# Format: 628123456789 (tanpa +, spasi, atau strip)
NEXT_PUBLIC_WHATSAPP_NUMBER=