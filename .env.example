# ─── Social Media ─────────────────────────────────────────────────────────────
# Salin file ini menjadi .env.local dan isi nilainya untuk development lokal.
# Untuk deployment, set variabel ini langsung di dashboard platform
# (Vercel: Settings → Environment Variables, Netlify: Site Settings → Env Vars, dst.)

NEXT_PUBLIC_SOCIAL_GITHUB=
NEXT_PUBLIC_SOCIAL_LINKEDIN=
NEXT_PUBLIC_SOCIAL_EMAIL=

# ─── GitHub Featured Projects ─────────────────────────────────────────────────
# Nama repo dipisah koma, contoh: my-app,another-repo,cool-project
GITHUB_FEATURED_REPOS=
# Token opsional untuk rate limit lebih tinggi (5000 req/jam vs 60 req/jam)
# GITHUB_TOKEN=
